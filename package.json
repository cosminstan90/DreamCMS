{
  "name": "dreamcms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "deploy": "git pull && npm install && npm run build && pm2 restart dreamcms",
    "perf-check": "ts-node scripts/perf-check.ts",
    "prelaunch:check": "ts-node scripts/prelaunch-check.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
